{
    "name": "RetailSale_DF2",
    "properties": {
        "type": "MappingDataFlow",
        "typeProperties": {
            "sources": [
                {
                    "dataset": {
                        "referenceName": "ds_Silver_DF2_Customer",
                        "type": "DatasetReference"
                    },
                    "name": "source1"
                },
                {
                    "dataset": {
                        "referenceName": "ds_Silver_DF2_Products",
                        "type": "DatasetReference"
                    },
                    "name": "source2"
                },
                {
                    "dataset": {
                        "referenceName": "ds_Parq_Silver_Sales",
                        "type": "DatasetReference"
                    },
                    "name": "source3"
                }
            ],
            "sinks": [
                {
                    "dataset": {
                        "referenceName": "ds_AZSQLDBCust",
                        "type": "DatasetReference"
                    },
                    "name": "GoldLayer"
                }
            ],
            "transformations": [
                {
                    "name": "ProductSales"
                },
                {
                    "name": "join1"
                }
            ],
            "scriptLines": [
                "source(output(",
                "          CustomerID as integer,",
                "          CustomerName as string,",
                "          Email as string,",
                "          Phone as string,",
                "          City as string,",
                "          Country as string,",
                "          CountryRank as long",
                "     ),",
                "     allowSchemaDrift: true,",
                "     validateSchema: false,",
                "     ignoreNoFilesFound: false,",
                "     format: 'parquet') ~> source1",
                "source(output(",
                "          ProductID as integer,",
                "          ProductName as string,",
                "          Category as string,",
                "          Price as decimal(10,2),",
                "          StockQuantity as integer,",
                "          StockLevel as long",
                "     ),",
                "     allowSchemaDrift: true,",
                "     validateSchema: false,",
                "     ignoreNoFilesFound: false,",
                "     format: 'parquet') ~> source2",
                "source(output(",
                "          SaleID as long,",
                "          CustomerID as long,",
                "          ProductID as long,",
                "          SaleDate as string,",
                "          Quantity as long,",
                "          TotalAmount as double",
                "     ),",
                "     allowSchemaDrift: true,",
                "     validateSchema: false,",
                "     ignoreNoFilesFound: false,",
                "     format: 'parquet') ~> source3",
                "source2, source3 join(source2@ProductID == source3@ProductID,",
                "     joinType:'right',",
                "     matchType:'exact',",
                "     ignoreSpaces: false,",
                "     broadcast: 'auto')~> ProductSales",
                "ProductSales, source1 join(source3@CustomerID == source1@CustomerID,",
                "     joinType:'left',",
                "     matchType:'exact',",
                "     ignoreSpaces: false,",
                "     broadcast: 'auto')~> join1",
                "join1 sink(allowSchemaDrift: true,",
                "     validateSchema: false,",
                "     deletable:false,",
                "     insertable:true,",
                "     updateable:false,",
                "     upsertable:false,",
                "     format: 'table',",
                "     skipDuplicateMapInputs: true,",
                "     skipDuplicateMapOutputs: true,",
                "     errorHandlingOption: 'stopOnFirstError') ~> GoldLayer"
            ]
        }
    }
}